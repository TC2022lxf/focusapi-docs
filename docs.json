{
  "$schema": "https://mintlify.com/docs.json",
  "name": "FocusAPI",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png",
    "href": "https://focusapi.cn"
  },
  "theme": "mint",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.ico",
  "navbar": {
    "links": [
      {
        "label": "控制台",
        "href": "https://focusapi.cn/dashboard/overview"
      }
    ],
    "primary": {
      "type": "button",
      "label": "快速开始",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {}
  },
  "seo": {
    "indexing": "all"
  },
  "redirects": [
    {
      "source": "/getting-started",
      "destination": "/quickstart"
    },
    {
      "source": "/getting-started/",
      "destination": "/quickstart"
    },
    {
      "source": "/installation",
      "destination": "/quickstart"
    },
    {
      "source": "/installation/",
      "destination": "/quickstart"
    },
    {
      "source": "/api",
      "destination": "/models/selection"
    },
    {
      "source": "/api/",
      "destination": "/models/selection"
    },
    {
      "source": "/models",
      "destination": "/models/selection"
    },
    {
      "source": "/models/",
      "destination": "/models/selection"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "开始",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "模型能力",
        "pages": [
          "models/selection",
          "models/chat",
          "models/image-analysis",
          "models/reasoning",
          "models/image-generation",
          "models/image-editing",
          "models/video-generation",
          "models/audio",
          "models/embedding-rerank",
          "models/multimodal",
          "models/tool-calling"
        ]
      },
      {
        "group": "计费与用量",
        "pages": ["billing/pricing"]
      },
      {
        "group": "错误排查",
        "pages": ["errors/overview", "errors/401", "errors/429", "errors/524"]
      },
      {
        "group": "常见问题",
        "pages": ["faq/common"]
      }
    ]
  }
}
